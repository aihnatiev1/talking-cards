/build/
# pubspec.lock is intentionally committed for this app project so CI
# (Xcode Cloud, Play Console) resolves the exact plugin versions Podfile.lock
# was generated against. Without it, `flutter pub get` on CI can float to a
# newer firebase_analytics whose iOS pods no longer match the lock.

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

